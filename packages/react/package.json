{
  "name": "@iconora/react",
  "version": "1.1.1",
  "description": "Iconora – Production-grade React SVG icon components. Tree-shakeable, TypeScript, accessible.",
  "license": "MIT",
  "homepage": "https://sudhanshuku01.github.io/iconora/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudhanshuku01/iconora.git"
  },
  "bugs": {
    "url": "https://github.com/sudhanshuku01/iconora/issues"
  },
  "keywords": ["icons","svg","react","iconora","typescript","components","tree-shakeable"],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@iconora/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "react": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
