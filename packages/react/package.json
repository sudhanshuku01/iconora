    "build": "tsup src/index.tsx --format esm,cjs --dts --clean --external react"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@iconora/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "react": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
