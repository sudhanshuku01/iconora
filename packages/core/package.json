{
  "name": "@iconora/core",
  "version": "1.1.1",
  "description": "Iconora – Raw SVG icon data for React, Vue, Svelte and Vanilla JS.",
  "license": "MIT",
  "homepage": "https://sudhanshuku01.github.io/iconora/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudhanshuku01/iconora.git"
  },
  "bugs": {
    "url": "https://github.com/sudhanshuku01/iconora/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "iconora",
    "typescript",
    "react",
    "vue",
    "svelte"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
