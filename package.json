{
  "name": "iconora",
  "version": "0.0.0",
  "private": true,
  "description": "Iconora – Production-grade SVG icon library",
  "scripts": {
    "build": "turbo run build --filter=!iconora && node scripts/generate-docs-data.mjs",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "optimize": "node scripts/optimize-svgs.mjs",
    "generate": "node scripts/generate-components.mjs && node scripts/generate-docs-data.mjs",
    "release": "changeset version && pnpm --filter ./packages/* publish -r --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^1.13.3",
    "svgo": "^3.2.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.6"
}
